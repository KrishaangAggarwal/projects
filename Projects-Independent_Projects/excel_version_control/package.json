{
    "name": "spreadsheet-version-control",
    "version": "1.0.0",
    "description": "Git-like version control for spreadsheets",
    "type": "module",
    "scripts": {
        "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
        "dev:server": "tsx watch server/index.ts",
        "dev:client": "vite",
        "build": "vite build && tsc -p tsconfig.server.json",
        "start": "node dist/server/index.js"
    },
    "dependencies": {
        "@hono/node-server": "^1.12.0",
        "@hono/zod-validator": "^0.2.2",
        "bcryptjs": "^2.4.3",
        "hono": "^4.5.8",
        "jose": "^5.6.3",
        "sql.js": "^1.10.3",
        "xlsx": "^0.18.5",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/node": "^22.5.0",
        "@types/react": "^18.3.4",
        "@types/react-dom": "^18.3.0",
        "@types/sql.js": "^1.4.9",
        "@vitejs/plugin-react": "^4.3.1",
        "autoprefixer": "^10.4.20",
        "concurrently": "^8.2.2",
        "postcss": "^8.4.41",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-router-dom": "^6.26.1",
        "tailwindcss": "^3.4.10",
        "tsx": "^4.19.0",
        "typescript": "^5.5.4",
        "vite": "^5.4.2"
    }
}
